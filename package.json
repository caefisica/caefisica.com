{
  "name": "@caefisica/web",
  "version": "0.9.6",
  "private": true,
  "author": "David Duran <contacto@altmails.com> (https://totallynotdavid.github.io/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/caefisica/web.git"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/totallynotdavid"
  },
  "scripts": {
    "init": "shx rm -rf .git && git init -b master",
    "clean": "bun run clean:build && bun run clean:packages",
    "clean:build": "shx rm -rf public resources",
    "clean:packages": "shx rm -rf node_modules bun-lock.yaml",
    "format:templates": "gotmplfmt -w layouts data",
    "hugo:create": "hugo new",
    "hugo:start": "hugo server --disableFastRender",
    "hugo:start:lan": "hugo server --bind=0.0.0.0 --baseURL=http://192.168.18.218 --port=1313",
    "build": "shx cp ./node_modules/katex/dist/fonts/* ./static/fonts/ && hugo --gc --minify",
    "build:lan": "shx cp ./node_modules/katex/dist/fonts/* ./static/fonts/ && hugo --gc --minify --baseURL=http://192.168.18.218",
    "build:preview": "bun run build -D -F",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run build",
    "hugo:version": "hugo version",
    "lint": "bun run lint:scripts && bun run lint:styles && bun run lint:markdown",
    "lint:scripts": "eslint assets/js config functions --ext .js,.ts",
    "lint:styles": "stylelint \"assets/scss/**/*.{css,sass,scss,sss,less}\"",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "test": "bun run lint",
    "copy:katex-fonts": "shx cp ./node_modules/katex/dist/fonts/* ./static/fonts/",
    "serve": "netlify functions:serve"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.8",
    "@eslint/js": "^10.0.1",
    "algoliasearch": "^5.52.1"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@thulite/images": "^3.3.4",
    "@types/youtube": "^0.2.0",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "clipboard": "^2.0.11",
    "dotenv": "^17.3.1",
    "encoding": "^0.1.13",
    "eslint": "^10.0.3",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "instant.page": "^5.2.0",
    "katex": "^0.17.0",
    "lazysizes": "^5.3.2",
    "markdownlint-cli2": "^0.22.1",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "prettier": "3.8.3",
    "purgecss-whitelister": "^2.4.0",
    "sass-embedded": "^1.98.0",
    "shx": "^0.4.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "browserslist": [
    "defaults"
  ]
}
